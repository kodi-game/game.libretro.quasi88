msgctxt "Addon Summary"
msgid "NEC - PC-8000 / PC-8800 series (QUASI88)"
msgstr "NEC - řada PC-8000 / PC-8800 (QUASI88)"

msgctxt "Addon Description"
msgid "QUASI88 is an emulator by Showzoh Fukunaga licensed under the BSD 3-Clause license. QUASI88 uses code from MAME, XMAME and fmgen."
msgstr "QUASI88 je emulátor od Showzoha Fukunagy s licencí BSD 3-Clause. QUASI88 používá kód z MAME, XMAME a fmgen."

